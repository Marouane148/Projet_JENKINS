# Configuration Jenkins Docker

## Ports
JENKINS_HOST_PORT=8080
JENKINS_AGENT_PORT=50000

## Environnement
JAVA_HOME=/opt/java/openjdk
MAVEN_HOME=/usr/share/maven

## JVM Options
JAVA_OPTS=-Xmx2048m -Xms512m
JENKINS_JAVA_OPTS=-Xmx2048m -Xms512m

## Identifiants GitHub
GITHUB_REPO=https://github.com/Marouane148/Projet_JENKINS.git
GITHUB_BRANCH=main

## Paramètres Maven
MAVEN_VERSION=3.9.6
JAVA_VERSION=Latest (inclus dans Jenkins)
